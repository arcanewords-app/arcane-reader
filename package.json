{
  "name": "arcane-reader",
  "version": "1.0.0",
  "description": "Web UI for Arcane novel translator",
  "type": "module",
  "main": "dist/server.js",
  "packageManager": "npm@10.x",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client:wait\" \"npm run dev:debug:wait\" \"npm run dev:prompt-lab:wait\"",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev:client:wait\" \"npm run dev:debug:wait\" \"npm run dev:prompt-lab:wait\" \"npm run worker\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:client": "vite",
    "dev:client:wait": "wait-on tcp:127.0.0.1:3000 && vite",
    "dev:debug": "vite --config vite.debug.config.ts",
    "dev:debug:wait": "wait-on tcp:127.0.0.1:3000 && vite --config vite.debug.config.ts",
    "dev:prompt-lab": "vite --config vite.prompt-lab.config.ts",
    "dev:prompt-lab:wait": "wait-on tcp:127.0.0.1:3000 && vite --config vite.prompt-lab.config.ts",
    "worker": "tsx watch src/worker.ts",
    "build": "npm run build:client && npm run build:debug && npm run build:prompt-lab && npm run build:server",
    "build:client": "vite build",
    "build:debug": "vite build --config vite.debug.config.ts",
    "build:prompt-lab": "vite build --config vite.prompt-lab.config.ts",
    "build:server": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "kill-port": "node scripts/kill-port.js",
    "csv-patterns": "tsx scripts/csv-pattern-replace.ts",
    "predev:force": "node scripts/kill-port.js 3000",
    "dev:force": "tsx watch src/server.ts",
    "lint": "eslint src",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "lint:all": "npm run lint && npm run lint:css && npm run typecheck",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.debug-app.json && tsc --noEmit -p tsconfig.prompt-lab-app.json",
    "test:language-pair": "tsx scripts/test-language-pair.ts",
    "test:editing-prompts": "tsx scripts/test-editing-prompt-combos.ts",
    "test:glossary-filter": "node --import tsx --test src/engine/glossary/glossary-filter.test.ts",
    "test:glossary-manager": "node --import tsx --test src/engine/glossary/glossary-manager.test.ts",
    "test:stage-prompt-flow": "node --import tsx --test src/engine/pipeline/stage-prompt-flow.test.ts",
    "test:para-markers": "node --import tsx --test src/engine/utils/para-markers.test.ts",
    "test:paragraph-translation-map": "node --import tsx --test src/shared/paragraphTranslationMap.test.ts",
    "test:paragraph-sync": "node --import tsx --test src/shared/paragraphSync.test.ts",
    "test:ai-replace": "node --import tsx --test src/engine/prompts/ai-replace.test.ts",
    "test:ai-replace-estimate": "node --import tsx --test src/shared/aiReplaceEstimate.test.ts",
    "test:scraper-chapter": "node --import tsx --test src/shared/scraperChapter.test.ts",
    "seed:news": "tsx scripts/seed-news-from-drafts.ts",
    "test:simple-markdown": "node --import tsx --test src/client/utils/simpleMarkdown.test.ts",
    "test:url-routes": "node --import tsx --test src/client/utils/urlRoutes.test.ts",
    "test:url-sync": "node --import tsx --test src/client/hooks/useUrlSync.test.ts src/client/utils/urlRoutes.test.ts",
    "test:openai-model-adapter": "node --import tsx --test src/shared/openaiModelAdapter.test.ts",
    "test:resolve-execution-options": "node --import tsx --test src/engine/pipeline/resolve-execution-options.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:deps": "tsx scripts/gen-dep-graph.ts",
    "check:circular": "tsx scripts/gen-dep-graph.ts --circular-only",
    "check:graphviz": "tsx scripts/gen-dep-graph.ts --check-graphviz",
    "audit:all": "npm audit",
    "audit:prod": "npm audit --omit=dev",
    "deps:outdated": "npm outdated",
    "prepare": "husky"
  },
  "keywords": [
    "novel",
    "translation",
    "reader",
    "ui"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@axiomhq/js": "^1.7.0",
    "@supabase/supabase-js": "^2.108.2",
    "@upstash/redis": "^1.38.0",
    "adm-zip": "^0.5.17",
    "bullmq": "^5.79.2",
    "cors": "^2.8.6",
    "csv-parse": "^7.0.0",
    "diff-match-patch": "^1.0.5",
    "dotenv": "^17.4.2",
    "epub-gen-memory": "^1.1.2",
    "epub2": "^3.0.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.9.3",
    "js-tiktoken": "^1.0.21",
    "multer": "^2.2.0",
    "openai": "^6.45.0",
    "petrovich": "^0.2.1",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.5",
    "@preact/signals": "^2.9.2",
    "@types/adm-zip": "^0.5.8",
    "@types/cors": "^2.8.17",
    "@types/diff-match-patch": "^1.0.36",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.0",
    "@vercel/node": "^5.8.22",
    "concurrently": "^10.0.3",
    "dompurify": "^3.4.11",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "i18next": "^26.3.3",
    "ioredis": "^5.11.1",
    "lint-staged": "^17.0.8",
    "madge": "^8.0.0",
    "pino-pretty": "^13.1.3",
    "preact": "^10.29.3",
    "preact-router": "^4.1.2",
    "prettier": "^3.9.1",
    "react-i18next": "^17.0.8",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10",
    "web-vitals": "^5.3.0"
  }
}
